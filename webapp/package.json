{
  "name": "ble-diagnostics-webapp",
  "version": "0.1.0",
  "private": true,
  "description": "Bluetooth diagnostics PWA wrapped by Capacitor for iOS builds",
  "scripts": {
    "clean:www": "node -e \"require('fs').rmSync('www',{recursive:true,force:true});\"",
    "build:web": "node ./scripts/build-web.mjs",
    "cap:sync:ios": "node ./scripts/build-web.mjs && npx cap sync ios"
  },
  "dependencies": {
    "@capacitor/core": "^7.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@capacitor/ios": "^7.2.0"
  }
}